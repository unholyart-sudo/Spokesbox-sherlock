# Spokesbox — example env (copy to .env and fill in real values)
# NEVER commit .env with real secrets.

SENDGRID_API_KEY=your-sendgrid-api-key
OPENAI_API_KEY=your-openai-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_ID=your-stripe-price-id
SESSION_SECRET=replace-with-random-string
PORT=3002
APP_BASE_URL=https://spokesbox.com
NODE_ENV=production

# Brief Tuning (PR 1)
# Generate TUNE_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TUNE_SECRET=replace-with-32-byte-random-hex
BRIEF_TUNING_ENABLED_SUBSCRIBERS=2
