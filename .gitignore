
# TorahTxt podcast audio — not committed unless explicitly approved
podcasts/daily-torah/**/*.mp3

# Environment files — never commit secrets
.env
.env.*
*.env
**/.env
**/.env.*

# Service account and credentials — never commit
google-service-account.json
google-vertex-service-account.json
*.pem
*.key
*.p12

# Backup artifacts — never commit
*.enc
production-critical/
backup.log

# Spokesbox send ledger — runtime files, not source
spokesbox/send-ledger/*.json

# SQLite runtime databases — NEVER commit live subscriber/app data
# git reset --hard will revert these to old snapshots, wiping live data
# See scripts/safe-git-reset.sh and torahtxt/DATABASE.md
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
