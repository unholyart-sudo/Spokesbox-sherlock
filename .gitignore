
# TorahTxt podcast audio — not committed unless explicitly approved
podcasts/daily-torah/**/*.mp3

# Environment files — never commit secrets
.env
.env.*
*.env
**/.env
**/.env.*

# Service account and credentials — never commit
google-service-account.json
google-vertex-service-account.json
*.pem
*.key
*.p12

# Backup artifacts — never commit
*.enc
production-critical/
backup.log

# Spokesbox send ledger — runtime files, not source
spokesbox/send-ledger/*.json
