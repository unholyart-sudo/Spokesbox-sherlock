# Spokesbox — required environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── Core ──────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.replace-me
OPENAI_API_KEY=sk-replace-me
SESSION_SECRET=generate-with-openssl-rand-hex-32
PORT=3002
APP_BASE_URL=https://spokesbox.com
NODE_ENV=production

# ── Social Enrichment (disabled by default) ────────────────────────────────
# Master switch. Must be explicitly set to 'true' to enable ANY social analysis.
# When false/absent: no external calls, no enrichment jobs, wizard works from
# explicit answers only.
SOCIAL_ENRICHMENT_ENABLED=false

# Which approved provider to use. Currently only 'brightdata' is supported.
# Data365 is not an approved provider and will not be used regardless of this setting.
SOCIAL_PROVIDER=brightdata

# Bright Data API key (required when SOCIAL_ENRICHMENT_ENABLED=true and SOCIAL_PROVIDER=brightdata)
# Get from: https://brightdata.com/cp/setting/users
BRIGHTDATA_API_KEY=

# Minimum LLM confidence score (0.0–1.0) for inferred topics to be shown to users.
# Topics below this threshold are silently dropped at merge time.
# Recommended: 0.70 or higher.
SOCIAL_MIN_CONFIDENCE=0.70

# Per-profile API request timeout in milliseconds.
# Applies to both provider HTTP calls and the OpenAI inference request.
SOCIAL_ENRICHMENT_TIMEOUT_MS=12000

# Maximum number of social profiles to process per session (guards against runaway API spend).
SOCIAL_MAX_PROFILES=3

# Maximum posts per profile sent to LLM inference (semantic pre-trim limit).
SOCIAL_MAX_POSTS_PER_PROFILE=15

# Maximum characters of text per profile sent to LLM (enforced before truncation).
SOCIAL_MAX_TEXT_CHARS=4000

# ── Private Beta Gate ─────────────────────────────────────────────────────────
# Set to enable site-wide password protection (private beta mode).
# When set, all routes except /health, /unsubscribe, /beta-login, and static
# assets require the correct password cookie.
# Leave blank/unset to disable the gate (standard public access).
SITE_PASSWORD=

# Set to 'true' when running a private beta. Controls UI disclosures.
BETA_MODE=false

# ── Sam Brief Generation (lib/brief_llm.js) ───────────────────────────────────
# Required for Sam brief generation (PR2). Uses Anthropic Claude — NOT OpenAI.
# OPENAI_API_KEY above is used only for content moderation and social enrichment.
ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional: override the default Claude model. Defaults to claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6
